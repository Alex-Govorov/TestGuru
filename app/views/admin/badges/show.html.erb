<div class="mt-4 row">
  <div class="col-2">
  <%= image_tag @badge.image_path, class: 'img-fluid' %>
  </div>

  <div class="row align-items-center">
    <div class="col">
    <strong><%= Badge.human_attribute_name(:title) %>:</strong>
    <%= @badge.title %>
    </div>

    <div class="col-12">
    <strong><%= Badge.human_attribute_name(:rule_name) %>:</strong>
    <%= badge_text_rule(@badge) %>
    </div>
  </div>

</div>

<div class="mt-3">
<%= link_to t(:back), admin_badges_path, class: 'btn btn-secondary' %>
<%= link_to t(:edit), edit_admin_badge_path(@badge), class: 'btn btn-primary' %>
</div>
