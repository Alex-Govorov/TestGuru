<% if @questions.exists? %>
	<h2><%= t('.header') %></h2>

	<table class="table">
    <thead>
		<tr>
			<th><%= Question.human_attribute_name(:body) %></th>
			<th colspan="3", class="text-center"><%= t('.actions') %></th>
		</tr>
    </thead>
    <tbody>
		<%= render @questions %>
    </tbody>
	</table>
<% end %>
<%= link_to t('.new_question'), new_admin_test_question_path(@test) %>
