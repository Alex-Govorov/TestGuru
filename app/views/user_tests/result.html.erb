<% if @user_test.successful? %>
	<h1><%= t('.header_success', title: @user_test.test.title) %></h1>
	<p> <%= t('.success_rate') %>: <span class="text-success"><%= @user_test.success_rate %>%</span></p>
<% else %>
	<h1><%= t('.header_fail', title: @user_test.test.title) %></h1>
	<p> <%= t('.success_rate') %>: <span class="text-danger"><%= @user_test.success_rate %>%</span></p>
<% end %>

<%= link_to t(:back), tests_path %>
